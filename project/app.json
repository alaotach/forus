{
  "expo": {
    "name": "forus",
    "slug": "couples-connection",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "couples-connection",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.alaotach.forus"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "googleServicesFile": "./google-services.json",
      "package": "com.alaotach.forus",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-audio",
      [
        "expo-media-library",
        {
          "granularPermissions": [
            "photo",
            "video",
            "audio"
          ]
        }
      ],
      "expo-secure-store",
      "expo-video",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#ff6b9d"
        }
      ],
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "ForusSharedCanvas",
              "label": "Forus Shared Canvas (5x3)",
              "description": "Shared photo, doodle and caption (5x3 default).",
              "minWidth": "300dp",
              "minHeight": "180dp",
              "targetCellWidth": 5,
              "targetCellHeight": 3,
              "resizeMode": "horizontal|vertical",
              "updatePeriodMillis": 1800000
            },
            {
              "name": "ForusSharedCanvas4x4",
              "label": "Forus Shared Canvas (4x4)",
              "description": "Shared photo, doodle and caption (4x4 preset).",
              "minWidth": "240dp",
              "minHeight": "240dp",
              "targetCellWidth": 4,
              "targetCellHeight": 4,
              "resizeMode": "horizontal|vertical",
              "updatePeriodMillis": 1800000
            },
            {
              "name": "ForusSharedCanvas3x3",
              "label": "Forus Shared Canvas (3x3)",
              "description": "Shared photo, doodle and caption (3x3 preset).",
              "minWidth": "180dp",
              "minHeight": "180dp",
              "targetCellWidth": 3,
              "targetCellHeight": 3,
              "resizeMode": "horizontal|vertical",
              "updatePeriodMillis": 1800000
            }
          ]
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "29c01ff4-4e9c-4f8d-8157-7698e33ea68c"
      }
    },
    "owner": "alaotach"
  }
}
