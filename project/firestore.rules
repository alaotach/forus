rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null && request.auth.uid != null;
    }
    
    // Helper function to check if the user is accessing their own data
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // Couple verification logic
    // A user can access resources if their document's coupleCode matches the resource's coupleCode
    function getCoupleCode() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.coupleCode;
    }
    
    function hasMatchingCoupleCode(resourceCoupleCode) {
      return isAuthenticated() && getCoupleCode() != null && getCoupleCode() == resourceCoupleCode;
    }

    // Match rules

    // Users Collection
    match /users/{uid} {
      allow read: if isAuthenticated();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || (
        // Allow a partner to link accounts by updating the partnerUid field
        isAuthenticated() && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['partnerUid', 'updatedAt'])
      );
    }
    
    // Couple Registry Collection (Used to join couples together)
    match /coupleRegistry/{coupleCode} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.createdByUid == request.auth.uid;
      allow update: if isAuthenticated(); // Simplified for joining flow
    }

    // Messages Collection
    match /messages/{messageId} {
      allow read: if hasMatchingCoupleCode(resource.data.coupleCode);
      allow create: if hasMatchingCoupleCode(request.resource.data.coupleCode);
      allow update: if hasMatchingCoupleCode(resource.data.coupleCode) && request.resource.data.coupleCode == resource.data.coupleCode;
      allow delete: if false; // Usually don't allow deleting messages, or restrict to owner
    }

    // Vault Items Collection
    match /vaultItems/{itemId} {
      allow read: if hasMatchingCoupleCode(resource.data.coupleCode);
      allow create: if hasMatchingCoupleCode(request.resource.data.coupleCode);
      allow update: if hasMatchingCoupleCode(resource.data.coupleCode) && request.resource.data.coupleCode == resource.data.coupleCode;
      allow delete: if hasMatchingCoupleCode(resource.data.coupleCode);
    }

    // Daily Paragraphs Collection
    match /dailyParagraphs/{paragraphId} {
      allow read: if hasMatchingCoupleCode(resource.data.coupleCode);
      allow create: if hasMatchingCoupleCode(request.resource.data.coupleCode);
      allow update: if hasMatchingCoupleCode(resource.data.coupleCode) && request.resource.data.coupleCode == resource.data.coupleCode;
      allow delete: if false;
    }

    // Matches any collection where the document ID *is* the coupleCode or the resource.data contains coupleCode
    // E.g. couples, streaks, coupleSecurity, subscriptions, deepTalks
    
    match /dailyPrompts/{id} {
      allow read, create, update: if isAuthenticated();
    }

    match /dailyDeepQuestions/{id} {
      allow read, create, update: if isAuthenticated();
    }

    match /promptCache/{id} {
      allow read, create, update: if isAuthenticated();
    }

    match /sharedDiary/{itemId} {
      allow read: if hasMatchingCoupleCode(resource.data.coupleCode);
      allow create: if hasMatchingCoupleCode(request.resource.data.coupleCode);
      allow update, delete: if hasMatchingCoupleCode(resource.data.coupleCode);
    }

    // Push Notifications / FCM Tokens Collection
    match /fcmTokens/{tokenId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isOwner(request.resource.data.uid);
    }

    match /{collection}/{coupleCode} {
      allow read: if hasMatchingCoupleCode(coupleCode) || (resource != null && 'coupleCode' in resource.data && hasMatchingCoupleCode(resource.data.coupleCode));
      allow create: if hasMatchingCoupleCode(coupleCode) || ('coupleCode' in request.resource.data && hasMatchingCoupleCode(request.resource.data.coupleCode));
      allow update: if hasMatchingCoupleCode(coupleCode) || (resource != null && 'coupleCode' in resource.data && hasMatchingCoupleCode(resource.data.coupleCode));
      allow delete: if hasMatchingCoupleCode(coupleCode) || (resource != null && 'coupleCode' in resource.data && hasMatchingCoupleCode(resource.data.coupleCode));
      
      // And allow all their subcollections 
      match /{subCollection}/{document=**} {
        allow read: if hasMatchingCoupleCode(coupleCode);
        allow create: if hasMatchingCoupleCode(coupleCode);
        allow update: if hasMatchingCoupleCode(coupleCode);
        allow delete: if hasMatchingCoupleCode(coupleCode);
      }
    }

    // Catch-all for unlisted collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
