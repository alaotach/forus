# AI configuration
HACKCLUB_API_KEY=your_hackclub_api_key_here

# Server config
PORT=3000
NODE_ENV=production

# Public URL clients should use for this backend
PUBLIC_BASE_URL=https://forus.eryzalabs.com

# Allowed web origins (comma-separated)
ALLOWED_ORIGINS=https://forus.eryzalabs.com

# API rate limiting (window in milliseconds)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=120
AI_RATE_LIMIT_MAX=40

# Media endpoint auth and rate limits
MEDIA_AUTH_JWT_SECRET=replace_with_strong_random_secret
MEDIA_AUTH_TOKEN_TTL_SECONDS=3600
MEDIA_UPLOAD_TICKET_TTL_SECONDS=900
MEDIA_RATE_LIMIT_WINDOW_MS=300000
MEDIA_RATE_LIMIT_MAX=180
MEDIA_METRICS_RECENT_EVENTS=100

# AWS private media storage
AWS_REGION=eu-north-1
AWS_S3_BUCKET=your_private_media_bucket
AWS_MEDIA_TABLE=your_media_metadata_table
S3_MAX_UPLOAD_BYTES=20971520
S3_UPLOAD_URL_TTL_SECONDS=300
S3_DOWNLOAD_URL_TTL_SECONDS=120

# Optional CloudFront signed delivery (recommended for production)
# Use either CLOUDFRONT_PRIVATE_KEY or CLOUDFRONT_PRIVATE_KEY_BASE64
CLOUDFRONT_DOMAIN=your-distribution.cloudfront.net
CLOUDFRONT_KEY_PAIR_ID=your_cloudfront_key_pair_id
# CLOUDFRONT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----"
# CLOUDFRONT_PRIVATE_KEY_BASE64=base64_encoded_private_key

# Optional: only for non-EC2 deployments without IAM role
# AWS_ACCESS_KEY_ID=your_access_key_id
# AWS_SECRET_ACCESS_KEY=your_secret_access_key
