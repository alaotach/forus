# AI configuration
HACKCLUB_API_KEY=your_hackclub_api_key_here

# Server config
PORT=3000
NODE_ENV=production

# Public URL your app should use to access this backend
PUBLIC_BASE_URL=http://10.102.93.34:3000

# EC2 disk path for media storage (your mounted data volume)
MEDIA_ROOT=/data/forus-media

# Optional upload auth token (recommended in production)
UPLOAD_API_TOKEN=replace_with_random_secret

# API rate limiting (window in milliseconds)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=120
AI_RATE_LIMIT_MAX=40
UPLOAD_RATE_LIMIT_MAX=30

# Upload restrictions
MAX_UPLOAD_SIZE_MB=15
